{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    // kết nối trực tiếp với console
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "enabled": true
    },
    "tailwindcss": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "tailwindcss-mcp-server"
      ],
      "enabled": true
    },
    // ghi nhớ hội thoại
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true
    },
    // cấp quyền cho ai trỏ thẳng vào file
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "C:\\Users\\tnanh\\Desktop"
      ],
      "enabled": true
    },
    // tự động viết teesst
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp"
      ],
      "enabled": true
    },
    "mongodb": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mongodb-mcp-server@latest"
      ],
      "env": {
        "MONGODB_URL": "mongodb+srv://username:password@your-cluster.mongodb.net/database_name"
      },
      "enabled": true
    },
    "github": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "YOUR_TOKEN_HERE"
      },
      "enabled": true
    },
    "fetch": {
      "type": "local",
      "command": [
        "python",
        "-m",
        "mcp_server_fetch"
      ],
      "enabled": true
    }
  }
}