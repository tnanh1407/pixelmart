{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "noEmit": false,
    "rewriteRelativeImportExtensions": true,
    "types": ["node"],
    "typeRoots": ["./node_modules/@types"]
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "dist",
    "tests",
    "**/?(*.)+(spec|test).ts",
    "**/__tests__/**"
  ]
}
