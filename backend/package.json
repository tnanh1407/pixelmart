{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "engines": {
    "node": ">=22.x"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "seed": "tsx src/scripts/seed.ts",
    "seed:reset": "tsx src/scripts/seed.ts --no-reset",
    "seed:dry": "tsx src/scripts/seed.ts --dry-run",
    "seed:fast": "tsx src/scripts/seed.ts --skip-cloudinary",
    "db:seed:addresses": "tsx src/scripts/seedAddresses.ts",
    "db:seed:campaign": "tsx src/scripts/seedCampaigns.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json -f -fe .js",
    "start": "cross-env NODE_ENV=production node dist/server.js",
    "test": "jest --no-cache",
    "test:watch": "jest --watchAll --no-cache",
    "test:ci": "jest --ci --coverage --no-cache",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
